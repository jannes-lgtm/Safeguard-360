# ── SafeGuard 360 — Environment Variables Reference ─────────────────────────
# Copy this file to .env and fill in real values for local development.
# All of these must also be set as Environment Variables in the Vercel dashboard
# for production. NEVER commit .env, .env.local, or .env.production to git.
#
# Legend:
#   [REQUIRED] — the platform will not start / feature will completely fail without this
#   [REQUIRED-CRON] — cron endpoints return 503 and refuse to run without this
#   [RECOMMENDED] — feature degrades gracefully but is incomplete without this
#   [OPTIONAL] — optional enhancement with a documented fallback

# ── Supabase ─────────────────────────────────────────────────────────────────
# [REQUIRED] Both VITE_ and non-VITE_ forms must be set.
# Frontend uses VITE_ prefix (Vite build-time injection).
# API routes use the non-VITE_ form (Node.js runtime).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # [REQUIRED] Admin key — server-side only, never expose to frontend

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...        # [REQUIRED] CAIRO, briefings, journey agent, AI assistant
VOYAGE_API_KEY=pa-...                     # [RECOMMENDED] Voyage AI — vector embeddings for CAIRO context search. Without this, CAIRO context assembly is disabled.

# ── Application URL ───────────────────────────────────────────────────────────
# [REQUIRED] Used to construct self-referencing API calls, email links, and webhook validation.
# Must match the canonical production domain exactly.
APP_URL=https://www.risk360.co

# ── Notifications — Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...                     # [REQUIRED] All email notifications disabled without this
RESEND_FROM_EMAIL=alerts@risk360.co       # [REQUIRED] Sender address; falls back to Resend sandbox if unset

# ── Notifications — SMS + WhatsApp (Twilio) ───────────────────────────────────
TWILIO_ACCOUNT_SID=AC...                  # [REQUIRED] Twilio account identifier
TWILIO_AUTH_TOKEN=...                     # [REQUIRED] Twilio auth token — used for SMS, WhatsApp, and webhook signature validation
TWILIO_FROM_NUMBER=+27000000000           # [REQUIRED] Verified Twilio phone number for SMS (non-WhatsApp)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 # [REQUIRED] WhatsApp-enabled Twilio number (currently sandbox — get production approval from Meta)
TWILIO_VALIDATE_SIG=true                  # [OPTIONAL] Set to "false" to disable Twilio webhook signature validation in local dev only

# ── SOS & Control Room routing ────────────────────────────────────────────────
# [REQUIRED] SOS alerts and missed check-in escalations are routed here.
# Without these, SOS events and missed check-ins are logged but not escalated.
SOS_ADMIN_EMAIL=sos@risk360.co
SOS_ADMIN_PHONE=+27000000000
SOS_ADMIN_WHATSAPP=+27000000000
CONTROL_ROOM_EMAIL=control@risk360.co
CONTROL_ROOM_PHONE=+27000000000
CONTROL_ROOM_WHATSAPP=+27000000000

# ── Cron security ─────────────────────────────────────────────────────────────
# [REQUIRED-CRON] All scheduled endpoints check Authorization: Bearer <secret>
# before executing. If unset, ALL cron functions return 503 and refuse to run.
# Use: openssl rand -hex 32
SCAN_SECRET=replace-with-random-32-char-secret     # Used by: scan-all
CRON_SECRET=replace-with-different-32-char-secret  # Used by: sos-escalation-check, missed-checkins, passport-expiry, trigger-debriefs, ingest-feeds, ops-analyze

# ── Beta gate ─────────────────────────────────────────────────────────────────
APP_GATE_PASSWORD=...                     # [REQUIRED] Beta access gate password shown to unauthenticated users
APP_GATE_SECRET=...                       # [REQUIRED] HMAC secret for gate token signing

# ── Mapping ───────────────────────────────────────────────────────────────────
VITE_MAPTILER_KEY=...                     # [RECOMMENDED] MapTiler — satellite and terrain map modes. Falls back to free CartoDB tiles.
VITE_W3W_API_KEY=...                      # [RECOMMENDED] What3Words — used for precise SOS location reporting

# ── Weather ───────────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=...                # [RECOMMENDED] Server-side weather alerts in country-risk
VITE_OPENWEATHERMAP_KEY=...              # [RECOMMENDED] Client-side weather overlay in MovementIntel and CountryRiskReport maps
                                          # Note: these are the SAME API key — both variables must be set to the same value

# ── Routing & Traffic ─────────────────────────────────────────────────────────
HERE_API_KEY=...                          # [RECOMMENDED] HERE Maps — route times and traffic data
GOOGLE_MAPS_API_KEY=...                   # [RECOMMENDED] Google Maps — secondary routing fallback

# ── Flight tracking ───────────────────────────────────────────────────────────
FLIGHTAWARE_API_KEY=...                   # [RECOMMENDED] FlightAware AeroAPI — live flight status

# ── Conflict intelligence ─────────────────────────────────────────────────────
ACLED_API_KEY=...                         # [RECOMMENDED] ACLED — structured conflict event data
ACLED_EMAIL=your@email.com                # [RECOMMENDED] Your registered ACLED account email

# ── Disease / health ──────────────────────────────────────────────────────────
HEALTHSITES_API_KEY=...                   # [RECOMMENDED] HealthSites.io — hospital and clinic data

# ── South Africa ──────────────────────────────────────────────────────────────
ESKOMSEPUSH_API_KEY=...                   # [OPTIONAL] EskomSePush — South Africa load shedding stage

# ── Cache (Upstash Redis) ─────────────────────────────────────────────────────
# [REQUIRED] All GDELT caching, distributed locks, and temp state depend on Redis.
# Without this, country-risk fetches are uncached (slow) and GDELT cron deduplication fails.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...             # [REQUIRED] Stripe secret key — checkout and billing portal disabled without this
STRIPE_WEBHOOK_SECRET=whsec_...           # [REQUIRED] Stripe webhook signing secret — events not verified without this (security risk)
STRIPE_SOLO_PRICE_ID=price_...            # [REQUIRED] Stripe Price ID for Solo plan
STRIPE_TEAM_PRICE_ID=price_...            # [REQUIRED] Stripe Price ID for Team plan
STRIPE_OPS_PRICE_ID=price_...             # [REQUIRED] Stripe Price ID for Ops/GSOC plan

# ── Notifications — admin ─────────────────────────────────────────────────────
ENTERPRISE_SALES_EMAIL=sales@risk360.co   # [OPTIONAL] Falls back to this hardcoded value if unset
ADMIN_NOTIFICATION_EMAIL=admin@risk360.co # [OPTIONAL] Falls back to this hardcoded value if unset

# ── Sentry — error monitoring ─────────────────────────────────────────────────
# Get DSN from: Sentry dashboard → Project Settings → Client Keys (DSN)
# Get AUTH_TOKEN from: Sentry → Settings → Auth Tokens → Create new token
SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/YYYYYYY  # [RECOMMENDED] Backend error capture — safe no-op if unset
SENTRY_AUTH_TOKEN=sntrys_...               # [OPTIONAL] Source map upload during build — only needed in CI/Vercel
SENTRY_ORG=your-org-slug                   # [OPTIONAL] Required alongside SENTRY_AUTH_TOKEN for source maps
SENTRY_PROJECT=safeguard360               # [OPTIONAL] Required alongside SENTRY_AUTH_TOKEN for source maps
VITE_SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/YYYYYYY  # [RECOMMENDED] Frontend error capture — same DSN as SENTRY_DSN
VITE_SENTRY_ENVIRONMENT=development        # [RECOMMENDED] Tags events: 'production' | 'staging' | 'development'
# VITE_SENTRY_RELEASE is injected automatically from VERCEL_GIT_COMMIT_SHA at build time
